datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String    @unique
  password  String
  name      String?
  avatar    String?
  bio       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  posts     Post[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  published   Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    Int?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  guestIp     String?

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  tags        Tag[]
  comments    Comment[]
  likes       Like[]
  favorites   Favorite[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  posts       Post[]
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts     Post[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 支持访客评论
  authorId  Int?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // 访客信息
  guestName   String?
  guestEmail  String?
  guestAvatar String?
  isGuest     Boolean  @default(false)

  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId  Int?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

model Like {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestIp   String?

  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestIp   String?

  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}
